# PartyKit WebSocket host for multi-user rooms.
# - Leave blank to run in single-player mode (seeded bots).
# - For local dev with `pnpm party:dev`, set: VITE_PARTY_HOST=127.0.0.1:1999
# - For production, set to your deployed PartyKit URL after `pnpm party:deploy`:
#   VITE_PARTY_HOST=turntable-fm.<your-partykit-username>.partykit.dev
VITE_PARTY_HOST=
